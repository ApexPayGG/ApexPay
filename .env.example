# Skopiuj do .env i uzupełnij (nie commituj .env).
#
# Poziom logów (Pino): trace | debug | info | warn | error | fatal. Produkcja zwykle info.
LOG_LEVEL=info
#
# Fraud detection (scoring 0–100; progi PASSED / FLAGGED / BLOCKED)
# FRAUD_MAX_CHARGES_PER_HOUR=10
# FRAUD_MAX_PAYOUTS_PER_DAY=3
# FRAUD_UNUSUAL_AMOUNT_MULTIPLIER=5
# FRAUD_DUPLICATE_WINDOW_MINUTES=5
# FRAUD_CARD_TESTING_THRESHOLD=3
# FRAUD_CARD_TESTING_MAX_AMOUNT=500
# FRAUD_MIN_ACCOUNT_AGE_HOURS=24
# FRAUD_NEW_ACCOUNT_MAX_AMOUNT=10000
# FRAUD_MAX_REFUND_RATE=0.3
# FRAUD_PAYOUT_SPIKE_MULTIPLIER=3
# FRAUD_SCORE_FLAG_THRESHOLD=30
# FRAUD_SCORE_BLOCK_THRESHOLD=70
#
# PowerShell (jednorazowo w tej sesji, zamiast .env):
#   $env:DATABASE_URL = "postgresql://root:secretpassword123@localhost:5432/apexpay_db?schema=public"
#   $env:JWT_SECRET = "min-32-znakow-losowy-ciag"
# (w bashu byłoby: export DATABASE_URL=...)
# Dev z docker-compose.yml (serwis db): baza to apexpay_db, user root / hasło jak w compose.
# DATABASE_URL=postgresql://root:secretpassword123@localhost:5432/apexpay_db?schema=public
# Inna instalacja Postgres — dopasuj nazwę bazy w URL do tej, którą utworzysz (CREATE DATABASE …).
DATABASE_URL=postgresql://USER:PASSWORD@localhost:5432/NAZWA_BAZY?schema=public
JWT_SECRET=zamien_na_dlugi_losowy_ciag_min_32_znaki
# Redis — idempotencja (charge/payout), rate limiting, cache. Lokalnie zwykle:
REDIS_URL=redis://127.0.0.1:6379
#
# Alerty operacyjne: dead letter webhooków (ostatnie 24 h, bez ręcznego requeue) — ostrzeżenie w logu gdy liczba > progu (domyślnie 10). Tick co 1 h (ten sam interwał co alerty sporów).
DEAD_LETTER_ALERT_THRESHOLD=10
#
# RabbitMQ — settlement (outbox), webhooki push (gdy ustawione). Lokalnie np. docker run … 5672.
# RABBITMQ_DEFAULT_USER=apexpay_admin
# RABBITMQ_DEFAULT_PASS=zmien_mnie_na_produkcji
# RABBITMQ_URL=amqp://apexpay_admin:zmien_mnie_na_produkcji@127.0.0.1:5672
# RABBITMQ_EXCHANGE=apexpay.events
# Za reverse proxy / WAF (Traefik, Cloudflare) ustaw np. 1 albo true
# TRUST_PROXY=1
#
# Rate limiting (Redis, fixed windows)
# Auth (POST /api/v1/auth/*): 15 minut, ochrona brute-force
RATE_LIMIT_AUTH_MAX=10
# Inicjacja płatności (POST /api/v1/payments/initiate): 15 minut
RATE_LIMIT_PAYMENTS_MAX=30
# Ogólne API /api/v1/*: 1 minuta (z wyłączeniem tras z dedykowanym limiterem)
RATE_LIMIT_API_GENERAL_MAX=100
# Webhooki PSP /internal/webhooks/* (POST): 1 minuta
RATE_LIMIT_WEBHOOKS_MAX=200
# Admin API /api/v1/admin/* (GET|POST): 1 minuta
RATE_LIMIT_ADMIN_MAX=50
# Opcjonalny bypass limitera dla zaufanych IP (CSV), np. monitoring/CI:
# RATE_LIMIT_TRUSTED_IPS=127.0.0.1,10.0.0.10

# Opcjonalnie: zbudowany front React pod tym samym portem co API (najpierw: npm run build --prefix frontend)
# APEXPAY_WEB_UI_DIR=./frontend/dist

# Portfel użytkownika platformy (zwroty marketplace: coveredBy PLATFORM / SPLIT — patrz docs/API.md).
# APEXPAY_PLATFORM_USER_ID=cmxxxxxxxxxxxxxxxxxxxxxxxx
#
# SAFE TAXI — rozliczenie przejazdu (pasażer → platforma + kierowca). Użytkownik platformy musi mieć portfel (np. zasilenie adminem).
# SAFE_TAXI_PLATFORM_USER_ID=cmxxxxxxxxxxxxxxxxxxxxxxxx
# SAFE_TAXI_PLATFORM_COMMISSION_BPS=1500
# Gotówka (paymentMethod CASH): prowizja z portfela kierowcy; saldo może być ujemne (BIGINT bez CHECK >= 0 w migracjach).
# Limit zadłużenia: MAX_DRIVER_DEBT ≤ 0 (minor units), np. -10000 = minimum -100 PLN. Puste = brak limitu.
# MAX_DRIVER_DEBT=-10000
# Legacy (dodatnia wielkość długu): MAX_DRIVER_DEBT_MINOR_UNITS=500000 → saldo ≥ -500000
SAFE_TAXI_PLATFORM_USER_ID=cmxxxxxxxxxxxxxxxxxxxxxxxx

# Autopay / Blue Media (v2.22.1) — inicjacja redirect + ITN XML (base64).
# ServiceID i SharedKey pobierasz z panelu Autopay.
# AUTOPAY_SERVICE_ID=123456
# AUTOPAY_SHARED_KEY=wstaw_hash_key_z_panelu
# Sandbox: https://pay-accept.bm.pl
# Produkcja: https://pay.bm.pl
# AUTOPAY_GATEWAY_URL=https://pay-accept.bm.pl
# URL powrotu klienta po płatności.
# AUTOPAY_RETURN_URL=https://app.twojadomena.pl/payments/return
# Publiczny endpoint ITN odbierający POST form-url-encoded z polem `transactions` (base64 XML).
# AUTOPAY_ITN_URL=https://api.twojadomena.pl/internal/webhooks/autopay-itn

# Minimalny zestaw (DEV) wymagany przez POST /api/v1/payments/initiate.
# Uzupełnij realnymi wartościami (zwłaszcza AUTOPAY_SHARED_KEY) przed użyciem.
AUTOPAY_SERVICE_ID=123456
AUTOPAY_SHARED_KEY=replace_with_real_autopay_shared_key
AUTOPAY_GATEWAY_URL=https://pay-accept.bm.pl
AUTOPAY_RETURN_URL=https://app.example.com/payments/return
AUTOPAY_ITN_URL=https://api.example.com/internal/webhooks/autopay-itn
