# Skopiuj do .env i uzupełnij (nie commituj .env).
#
# PowerShell (jednorazowo w tej sesji, zamiast .env):
#   $env:DATABASE_URL = "postgresql://root:secretpassword123@localhost:5432/apexpay_db?schema=public"
#   $env:JWT_SECRET = "min-32-znakow-losowy-ciag"
# (w bashu byłoby: export DATABASE_URL=...)
# Dev z docker-compose.yml (serwis db): baza to apexpay_db, user root / hasło jak w compose.
# DATABASE_URL=postgresql://root:secretpassword123@localhost:5432/apexpay_db?schema=public
# Inna instalacja Postgres — dopasuj nazwę bazy w URL do tej, którą utworzysz (CREATE DATABASE …).
DATABASE_URL=postgresql://USER:PASSWORD@localhost:5432/NAZWA_BAZY?schema=public
JWT_SECRET=zamien_na_dlugi_losowy_ciag_min_32_znaki
# Opcjonalnie (domyślnie redis://127.0.0.1:6379)
# REDIS_URL=redis://127.0.0.1:6379
# Za reverse proxy / WAF (Traefik, Cloudflare) ustaw np. 1 albo true
# TRUST_PROXY=1
#
# Rate limity API (okno w ms)
# AUTH_RATE_WINDOW_MS=60000
# AUTH_RATE_MAX_REQUESTS=25
# ADMIN_FUND_RATE_WINDOW_MS=60000
# ADMIN_FUND_RATE_MAX_REQUESTS=20

# Opcjonalnie: zbudowany front React pod tym samym portem co API (najpierw: npm run build --prefix frontend)
# APEXPAY_WEB_UI_DIR=./frontend/dist

# SAFE TAXI — rozliczenie przejazdu (pasażer → platforma + kierowca). Użytkownik platformy musi mieć portfel (np. zasilenie adminem).
# SAFE_TAXI_PLATFORM_USER_ID=cmxxxxxxxxxxxxxxxxxxxxxxxx
# SAFE_TAXI_PLATFORM_COMMISSION_BPS=1500
