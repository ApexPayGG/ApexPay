# Szablon produkcji — lokalna kopia (nie commituj): npm run ops:init-prod-env
# Nazwij plik .env.prod (docker compose / skrypty VPS). Nie „prod.env” — łatwo o pomyłkę z gitem.
#
# URL z hasłem (DATABASE_URL, RABBITMQ_URL): znaki specjalne muszą być URL-encoded,
# inaczej parser urwie hasło przy pierwszym @. Np. @ -> %40, : -> %3A, / -> %2F, ? -> %3F, # -> %23.
# W POSTGRES_PASSWORD / RABBITMQ_PASSWORD zwykle zostawiasz surowe hasło (bez %40).
#
# Domeny
API_DOMAIN=api.apexpay.pl
APP_DOMAIN=apexpay.pl
ACME_EMAIL=infra@apexpay.pl

# Obrazy (ustawiane takze przez deploy workflow)
# Przykład: repo GitHub ApexPayGG/ApexPay → ghcr.io/apexpaygg/apexpay/...
APEXPAY_API_IMAGE=ghcr.io/owner/repo/apexpay-api:latest
APEXPAY_WEB_IMAGE=ghcr.io/owner/repo/apexpay-web:latest
# Build SPA (GitHub Actions: zmienna repozytorium VITE_API_URL, np. https://api.apexpay.pl)
# VITE_API_URL=https://api.apexpay.pl

# Runtime API
JWT_SECRET=replace_with_long_random_secret
TRUST_PROXY=1
CORS_ORIGIN=https://apexpay.pl

# App-layer rate limit
AUTH_RATE_WINDOW_MS=60000
AUTH_RATE_MAX_REQUESTS=25
ADMIN_FUND_RATE_WINDOW_MS=60000
ADMIN_FUND_RATE_MAX_REQUESTS=20

# Edge-layer rate limit (Traefik)
TRAEFIK_API_RATE_AVERAGE=150
TRAEFIK_API_RATE_BURST=300

# Self-hosted database/cache/broker (uzyj z --profile selfhosted)
POSTGRES_USER=root
POSTGRES_PASSWORD=change_me
POSTGRES_DB=apexpay_db
DATABASE_URL=postgresql://root:change_me@postgres:5432/apexpay_db?schema=public
REDIS_URL=redis://redis:6379
RABBITMQ_USER=apexpay
RABBITMQ_PASSWORD=change_me
RABBITMQ_URL=amqp://apexpay:change_me@rabbitmq:5672
RABBITMQ_EXCHANGE=apexpay.events

# Webhooki
PSP_DEPOSIT_WEBHOOK_SECRET=
