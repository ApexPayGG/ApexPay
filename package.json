{
  "name": "apexpay-api",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "build": "tsc",
    "build:web": "npm run build --prefix frontend",
    "build:all": "npm run build && npm run build:web",
    "start": "node dist/server.js",
    "dev:api": "cross-env LOG_LEVEL=debug tsx watch src/server.ts",
    "dev:web": "npm run dev --prefix frontend",
    "dev": "concurrently -n api,web -c blue,magenta \"npm run dev:api\" \"npm run dev:web\"",
    "typecheck:api": "tsc --noEmit --pretty false",
    "typecheck:web": "npm run typecheck --prefix frontend",
    "typecheck": "npm run typecheck:api && npm run typecheck:web",
    "lint:api": "npm run typecheck:api",
    "lint:web": "npm run lint --prefix frontend",
    "lint": "npm run lint:api && npm run lint:web",
    "prisma:generate": "prisma generate",
    "prisma:validate": "prisma validate",
    "prisma:migrate": "prisma migrate dev",
    "test": "vitest run",
    "stress:idempotency": "tsx src/scripts/stress-test-idempotency.ts",
    "stress:db-locks": "tsx src/scripts/stress-test-db-locks.ts",
    "test:stress:seed": "tsx src/scripts/seed-disputed-match.ts",
    "test:stress:db-locks:auto": "tsx src/scripts/run-stress-with-seed.ts db-locks",
    "test:stress:idempotency:auto": "tsx src/scripts/run-stress-with-seed.ts idempotency",
    "ci:generate-jwt": "tsx src/scripts/generate-ci-jwt.ts",
    "db:check-bloat": "tsx src/scripts/check-db-bloat.ts",
    "ops:check-env": "tsx scripts/check-apexpay-env.ts",
    "ops:vps-compose": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/vps-apply-prod-compose.ps1",
    "ops:vps-compose:sh": "bash ./scripts/vps-apply-prod-compose.sh",
    "ops:vps-traefik": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/vps-update-traefik-compose.ps1",
    "ops:vps-web": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/vps-remote-recreate-web.ps1",
    "ops:vps-web:sh": "bash ./scripts/vps-remote-recreate-web.sh",
    "ops:vps-sync:sh": "bash ./scripts/sync-prod-compose-to-server.sh",
    "ops:init-prod-env": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/init-env-prod.ps1",
    "smoke:local": "tsx src/scripts/smoke-local.ts",
    "smoke:local:admin": "tsx src/scripts/smoke-local.ts --require-admin",
    "smoke:local:tournament": "tsx src/scripts/smoke-local.ts --require-admin --tournament",
    "load:payment": "node -e \"require('fs').mkdirSync('load-tests/results',{recursive:true})\" && k6 run --out json=load-tests/results/payment-flow.json load-tests/scenarios/payment-flow.ts",
    "load:charges": "node -e \"require('fs').mkdirSync('load-tests/results',{recursive:true})\" && k6 run --out json=load-tests/results/concurrent-charges.json load-tests/scenarios/concurrent-charges.ts",
    "load:webhooks": "node -e \"require('fs').mkdirSync('load-tests/results',{recursive:true})\" && k6 run --out json=load-tests/results/webhook-storm.json load-tests/scenarios/webhook-storm.ts",
    "load:fraud": "node -e \"require('fs').mkdirSync('load-tests/results',{recursive:true})\" && k6 run --out json=load-tests/results/fraud-detection.json load-tests/scenarios/fraud-detection.ts",
    "load:all": "bash load-tests/run.sh"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "module",
  "devDependencies": {
    "@types/amqplib": "^0.10.8",
    "@types/bcrypt": "^6.0.0",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/k6": "^1.7.0",
    "@types/node": "^25.5.0",
    "@types/node-cron": "^3.0.11",
    "@types/opossum": "^8.1.9",
    "@types/pg": "^8.20.0",
    "@types/pino-http": "^5.8.4",
    "@types/supertest": "^7.2.0",
    "@types/xml2js": "^0.4.14",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "pino-pretty": "^13.1.3",
    "supertest": "^7.2.2",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "vitest": "^4.1.2"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.6.0",
    "@prisma/client": "^7.6.0",
    "amqplib": "^1.0.2",
    "axios": "^1.15.0",
    "bcrypt": "^6.0.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "helmet": "^8.1.0",
    "ioredis": "^5.10.1",
    "jsonwebtoken": "^9.0.3",
    "node-cron": "^4.2.1",
    "opossum": "^9.0.0",
    "pg": "^8.20.0",
    "pino": "^10.3.1",
    "pino-http": "^11.0.0",
    "prisma": "^7.6.0",
    "prom-client": "^15.1.3",
    "socket.io": "^4.8.3",
    "socket.io-client": "^4.8.3",
    "xml2js": "^0.6.2",
    "zod": "^4.3.6"
  }
}
