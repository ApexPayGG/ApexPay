# --- Development (npm run dev) ---
# Zostaw VITE_API_URL puste: żądania idą na /api/... na hoście Vite (localhost:5173),
# a Vite proxy przekazuje je na backend (domyślnie http://127.0.0.1:3000).
# VITE_API_URL=

# Opcjonalnie: inny adres backendu podczas dev (np. Docker na innym porcie)
# VITE_API_PROXY_TARGET=http://127.0.0.1:3000

# --- Production (npm run build / Dockerfile.web) ---
# Opcjonalnie: osobny origin API. Na VPS nginx w obrazie web proxy'uje /api/ → kontener api — wtedy
# VITE_API_URL może być puste (żądania na ten sam host co strona).
# Pełny URL tylko jako origin — bez /login: https://apexpay.pl lub https://api.apexpay.pl
# VITE_API_URL=https://api.apexpay.pl
